# Wajib diisi kalau frontend mau pakai Supabase Auth, Realtime, dan direct table access.
VITE_SUPABASE_URL="https://PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Disarankan untuk frontend modern Supabase.
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# true  = frontend baca/tulis sebagian data langsung ke Supabase
# false = frontend pakai backend API saja
VITE_USE_SUPABASE_DATA="true"

# Local dev:
# VITE_API_BASE_URL="http://localhost:5001/api"
# Production same-domain reverse proxy:
# VITE_API_BASE_URL="/api"
# Production separate frontend/backend hosting:
VITE_API_BASE_URL="https://your-backend-domain.example/api"
