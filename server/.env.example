# Supabase Transaction/Connection Pooler.
# Ambil dari: Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct connection.
# Wajib dipakai Prisma untuk schema sync / migration yang tidak cocok lewat pooler.
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Manual SQL migrations akan jalan otomatis saat build deploy / start server.
# Pastikan DATABASE_URL menunjuk koneksi Postgres yang bisa mengeksekusi DDL.

PORT="5001"
HOST="0.0.0.0"

# Optional for server-side Supabase admin actions.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
